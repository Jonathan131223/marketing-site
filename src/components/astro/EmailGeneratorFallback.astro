---
/**
 * Plain-HTML loading fallback for the email generator React island.
 *
 * Rendered by Astro as the children of <EmailGeneratorApp client:only="react">
 * via the `slot="fallback"` pattern. Shows a spinner + helpful recovery copy
 * until React hydrates and replaces the DOM. If React never hydrates (JS
 * bundle 404, ad-blocker breaking the script, third-party extension
 * injection), the user sees this forever — which is infinitely better than
 * a blank white page, because it includes a "clear cache and reload"
 * escape hatch that does not require React.
 *
 * A <noscript> fallback additionally tells users who have disabled JS what
 * is going on, instead of leaving them staring at the spinner.
 *
 * The onclick handler uses vanilla JS (no React dependency) and clears
 * every localStorage key that starts with digistorms- or contains
 * email-generator, then reloads.
 */
---

<div
  slot="fallback"
  class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-50 flex items-center justify-center px-6"
>
  <div class="text-center max-w-md">
    <div
      class="w-10 h-10 border-4 border-[#2563EB] border-t-transparent rounded-full mx-auto mb-4 email-gen-spin"
    >
    </div>
    <p class="text-sm font-medium text-slate-500 mb-6">
      Loading lifecycle email generator…
    </p>
    <noscript>
      <p class="text-sm text-slate-600 mb-4">
        This page needs JavaScript to work. Please enable it or use a
        different browser.
      </p>
    </noscript>
    <details class="text-xs text-slate-400 mt-8">
      <summary class="cursor-pointer hover:text-slate-600">
        Stuck on this loading screen?
      </summary>
      <p class="mt-3">
        Your browser may be holding an outdated cache. Click the button
        below to clear local state and reload.
      </p>
      <button
        type="button"
        onclick="try{for(let i=localStorage.length-1;i>=0;i--){const k=localStorage.key(i);if(k&&(k.startsWith('digistorms_')||k.startsWith('digistorms-')||k.includes('email-generator')||k.startsWith('digi-marketing')))localStorage.removeItem(k);}try{sessionStorage.clear();}catch(e){}}catch(e){}location.reload();"
        class="mt-3 inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#2563EB] text-white font-semibold hover:bg-[#1D4ED8] transition-colors"
      >
        Clear cache and reload
      </button>
    </details>
  </div>
</div>

<style>
  @keyframes email-gen-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .email-gen-spin {
    animation: email-gen-spin 0.8s linear infinite;
  }
</style>
