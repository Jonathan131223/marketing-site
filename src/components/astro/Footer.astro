---
---

<footer class="bg-background-warm text-slate-900">
  <div class="container mx-auto px-4 py-16 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-6 gap-8">
      <div class="col-span-1 md:col-span-1">
        <div class="mb-4">
          <a href="/">
            <img
              src="/images/logo.webp"
              alt="DigiStorms"
              class="h-8 w-auto mb-4"
              style="mix-blend-mode: multiply;"
              width="120"
              height="32"
            />
          </a>
        </div>
        <p class="text-slate-600 mb-4">
          Turn free users into paying customers, on autopilot.
        </p>
        <div class="flex space-x-4">
          <a
            href="https://x.com/digistorms_ai"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="DigiStorms on X (Twitter)"
            class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center justify-center min-h-[44px] min-w-[44px]"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/digi-storms/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="DigiStorms on LinkedIn"
            class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center justify-center min-h-[44px] min-w-[44px]"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4 text-slate-900">Library</h4>
        <ul class="space-y-2">
          <li><a href="/library" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Email Library</a></li>
          <li><a href="/library/brands" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Browse by Brand</a></li>
          <li><a href="/library/usecases" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Browse by Use Case</a></li>
          <li><a href="/library/tags" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Browse by Tag</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4 text-slate-900">Product</h4>
        <ul class="space-y-2">
          <li><a href="/manifesto" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Manifesto</a></li>
          <li><a href="/pricing" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Pricing</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4 text-slate-900">Resources</h4>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Blog</a></li>
          <li><a href="/lifecycle-score" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Your Onboarding Score</a></li>
          <li><a href="/roi-calculator" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">ROI Calculator</a></li>
          <li><a href="/email-generator" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Lifecycle Email Generator</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4 text-slate-900">Compare</h4>
        <ul class="space-y-2">
          <li><a href="/compare/digistorms-vs-customer-io" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">vs Customer.io</a></li>
          <li><a href="/compare/digistorms-vs-encharge" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">vs Encharge</a></li>
          <li><a href="/compare/digistorms-vs-loops" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">vs Loops</a></li>
          <li><a href="/compare/digistorms-vs-resend" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">vs Resend</a></li>
          <li><a href="/compare/best-onboarding-email-tools" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Best Email Tools</a></li>
          <li><a href="/compare/customer-io-alternatives" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Customer.io Alternatives</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-lg mb-4 text-slate-900">Company</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">About</a></li>
          <li><a href="/contact" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Contact</a></li>
          <li><a href="/privacy" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Privacy policy</a></li>
          <li><a href="/terms" class="text-slate-600 hover:text-slate-900 transition-colors inline-flex items-center min-h-[44px]">Terms of service</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-200 mt-12 pt-8">
      <p class="text-slate-600 text-sm">
        &copy; 2026 DigiStorms. All rights reserved.
      </p>
    </div>
  </div>
</footer>
