---
import '@fontsource/instrument-sans/400.css';
import '@fontsource/instrument-sans/500.css';
import '@fontsource/instrument-sans/600.css';
import '@fontsource/instrument-sans/700.css';
import '@fontsource/kalam/400.css';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  ogTitle?: string;
  ogDescription?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const siteUrl = 'https://www.digistorms.ai';
// Normalize to a single canonical form (no trailing slash, except root).
// Belt-and-braces with `trailingSlash: 'never'` in astro.config.mjs and
// `trailingSlash: false` in vercel.json — also protects explicit `canonical`
// props passed by pages from accidentally diverging.
const normalizePath = (p: string) => (p.length > 1 ? p.replace(/\/+$/, '') : p);
const {
  title,
  description,
  canonical = new URL(normalizePath(Astro.url.pathname), siteUrl).href,
  ogImage = `${siteUrl}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`,
  ogType = 'website',
  ogTitle = title,
  ogDescription = description,
  jsonLd,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#1D4ED8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      />
    </noscript>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta property="og:site_name" content="DigiStorms" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content="@digistorms_ai" />
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((item) => (
            <script type="application/ld+json" set:html={JSON.stringify(item)} />
          ))
        : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    {/*
      Strip tracking-only query params (GA cross-domain `_gl`, `_ga`, `_ga_*`,
      `gclid`, `fbclid`, `msclkid`, `ttclid`) on page load. GA's cross-domain
      linker appends `_gl=...` when navigating between digistorms.ai and
      app.digistorms.ai; without this the URL bar shows ugly tracking blobs.
      Inline so it fires before paint — `replaceState` rewrites the URL
      without reloading or losing GA's already-read cookie.
    */}
    <script is:inline>
      (function () {
        try {
          var url = new URL(window.location.href);
          var keys = ["_gl", "_ga", "gclid", "fbclid", "msclkid", "ttclid"];
          var changed = false;
          var paramKeys = [];
          url.searchParams.forEach(function (_v, k) { paramKeys.push(k); });
          for (var i = 0; i < paramKeys.length; i++) {
            var k = paramKeys[i];
            if (keys.indexOf(k) !== -1 || k.indexOf("_ga_") === 0) {
              url.searchParams.delete(k);
              changed = true;
            }
          }
          if (changed) {
            window.history.replaceState(window.history.state, "", url.pathname + url.search + url.hash);
          }
        } catch (_e) {}
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      import { initPostHog } from '@/lib/posthog';
      initPostHog();
    </script>
  </body>
</html>
