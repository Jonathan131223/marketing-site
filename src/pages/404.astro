---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="404 - Page Not Found | DigiStorms"
  description="The page you're looking for doesn't exist or has been moved."
  noindex={true}
>
  <main class="flex-1 flex flex-col items-center justify-center px-4 py-24 text-center">
    <p class="text-5xl font-bold mb-4" style="color: #1D4ED8;">404</p>
    <h1 class="text-2xl font-serif font-semibold text-slate-900 mb-3">Page not found</h1>
    <p class="text-slate-500 text-base max-w-sm mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-sm font-medium text-white transition-colors"
        style="background-color: #1D4ED8;"
      >
        Back to home
      </a>
      <a
        href="/blog"
        class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-sm font-medium border border-slate-200 text-slate-700 hover:bg-slate-50 transition-colors"
      >
        Browse the blog
      </a>
    </div>
  </main>
</PageLayout>
