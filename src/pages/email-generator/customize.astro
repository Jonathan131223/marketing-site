---
import BaseLayout from '@/layouts/BaseLayout.astro';
import EmailGeneratorApp from '@/components/react/EmailGeneratorApp';
import EmailGeneratorFallback from '@/components/astro/EmailGeneratorFallback.astro';
---

<BaseLayout
  title="Customize Your Email — DigiStorms Email Generator"
  description="Edit and customize your AI-generated lifecycle email with our visual editor."
  canonical="https://www.digistorms.ai/email-generator"
  noindex={true}
>
  <EmailGeneratorApp client:only="react">
    <EmailGeneratorFallback slot="fallback" />
  </EmailGeneratorApp>
</BaseLayout>
