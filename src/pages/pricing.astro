---
import PageLayout from '@/layouts/PageLayout.astro';
import PricingSelfServe from '@/components/react/PricingSelfServe';

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "DigiStorms",
  "url": "https://www.digistorms.ai",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "AI agent for onboarding emails. Analyzes your product and builds lifecycle email sequences automatically.",
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "USD",
    "lowPrice": "0",
    "highPrice": "149",
    "offerCount": "5",
    "url": "https://www.digistorms.ai/pricing",
    "offers": [
      {
        "@type": "Offer",
        "name": "Free",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Up to 100 onboarded users",
        "url": "https://www.digistorms.ai/pricing"
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "price": "19",
        "priceCurrency": "USD",
        "description": "Up to 1,000 onboarded users",
        "url": "https://www.digistorms.ai/pricing"
      },
      {
        "@type": "Offer",
        "name": "Business",
        "price": "59",
        "priceCurrency": "USD",
        "description": "Up to 5,000 onboarded users",
        "url": "https://www.digistorms.ai/pricing"
      },
      {
        "@type": "Offer",
        "name": "Scale",
        "price": "149",
        "priceCurrency": "USD",
        "description": "Up to 10,000 onboarded users",
        "url": "https://www.digistorms.ai/pricing"
      }
    ]
  }
};

// FAQPage schema — AI engines (ChatGPT, Perplexity, Google AI Overviews)
// pull pricing FAQ structured data directly into responses. Keep the
// questions aligned with the actual UX (free tier limits, plan differences,
// export portability, setup time, integration requirements).
//
// The Q&A *text* below is rendered visibly on the page (see the FAQ section
// in the <main> below). Google's Rich Results validator rejects FAQPage
// schema when the answers are not visible in the HTML — flagged on this
// page in the Ahrefs audit. If you edit either side, edit both.
const pricingFaqs = [
  {
    question: "What's included in the free DigiStorms plan?",
    answer: "The free plan includes 100 new signups per month, the full 7-email onboarding sequence generation, behavior-based triggers, and access to the email library with 1,058 real SaaS examples. No credit card required.",
  },
  {
    question: "What's the difference between Pro, Business, and Scale?",
    answer: "Plans differ by monthly new-signup volume: Pro is $19/mo for 1,000 signups, Business is $59/mo for 5,000 signups, and Scale is $149/mo for 10,000 signups. All plans include the full onboarding sequence generation, behavior-based triggers, and email library access.",
  },
  {
    question: "Can I export my email sequences to another tool?",
    answer: "Yes. Every sequence DigiStorms generates can be exported as plain HTML or Markdown and adapted to any email platform — Customer.io, Encharge, Loops, Resend, Mailchimp, ConvertKit, and more.",
  },
  {
    question: "How long does setup take?",
    answer: "Under 10 minutes for most SaaS products. DNS setup is ~1 minute, the product analysis runs in ~3 minutes, sequence review takes 5 minutes, and the event API integration is ~5 minutes.",
  },
  {
    question: "Do I need a credit card to start?",
    answer: "No. The free plan covers your first 100 new signups every month without a credit card. You only enter payment details when upgrading to Pro, Business, or Scale.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: pricingFaqs.map((f) => ({
    "@type": "Question",
    name: f.question,
    acceptedAnswer: { "@type": "Answer", text: f.answer },
  })),
};

const jsonLd = [softwareJsonLd, faqJsonLd];
---

<PageLayout
  ogImage="https://www.digistorms.ai/og/pricing.webp"
  title="SaaS Onboarding Email Pricing — DigiStorms"
  description="Simple, transparent pricing. Free for your first 100 users, then $19/$59/$149 monthly tiers. Your onboarding email system live in minutes."
  jsonLd={jsonLd}
>
  <main>
    <!-- Header -->
    <div class="mx-auto max-w-4xl px-6 pt-24 pb-10 text-center">
      <p class="text-[13px] font-semibold tracking-[0.08em] uppercase text-primary mb-3">
        Pricing
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-4">
        Onboarding that <span class="italic text-primary">runs itself</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-lg mx-auto mb-10">
        Pay for the users you onboard — nothing else.
      </p>
    </div>

    <!-- Pricing cards (interactive: toggle + tier stepper) -->
    <div class="mx-auto max-w-4xl px-6 pb-20">
      <PricingSelfServe client:load />
    </div>

    <!-- FAQ — answers also live in faqJsonLd above. Keep the two in sync. -->
    <section class="bg-background-warm py-16 sm:py-20">
      <div class="container mx-auto px-6 max-w-[720px]">
        <div class="text-center mb-10">
          <p class="text-[13px] font-semibold tracking-[0.08em] uppercase text-primary mb-3">
            Pricing FAQ
          </p>
          <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em]">
            Pricing, plans, and getting started
          </h2>
        </div>

        <div class="space-y-4">
          {pricingFaqs.map((faq) => (
            <details class="bg-white border border-slate-100/80 rounded-xl shadow-sm overflow-hidden group">
              <summary class="text-left text-base font-medium text-slate-900 px-6 py-5 cursor-pointer hover:bg-slate-50 transition-colors list-none flex items-center justify-between">
                <span>{faq.question}</span>
                <svg class="h-4 w-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 text-[15px] leading-relaxed border-t border-slate-100 pt-4">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
</PageLayout>
