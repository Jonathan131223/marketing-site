---
import PageLayout from '@/layouts/PageLayout.astro';
import brandsData from '@/data/library/brands.json';

const SITE_URL = 'https://www.digistorms.ai';
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`;

const sortedBrands = [...(brandsData as any[])].sort((a, b) => a.name.localeCompare(b.name));

const PAGE_TITLE = 'Browse Email Library by Brand | DigiStorms';
const PAGE_DESC = 'Explore lifecycle emails from 35+ leading B2B SaaS brands. See onboarding, engagement, upsell, and retention emails from companies like Notion, Loom, and Calendly.';
const pageUrl = `${SITE_URL}/library/brands`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: PAGE_TITLE,
  description: PAGE_DESC,
  url: pageUrl,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Library", item: `${SITE_URL}/library` },
      { "@type": "ListItem", position: 2, name: "Brands", item: pageUrl },
    ],
  },
};
---

<PageLayout
  title={PAGE_TITLE}
  description={PAGE_DESC}
  canonical={pageUrl}
  ogTitle={PAGE_TITLE}
  ogDescription={PAGE_DESC}
  ogImage={DEFAULT_OG_IMAGE}
  jsonLd={jsonLd}
>
  <main class="pt-16">
    <!-- Page header -->
    <div class="bg-white border-b border-slate-100 pb-8 pt-10">
      <div class="container mx-auto px-4 max-w-6xl">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/library" class="hover:text-[#1D4ED8] transition-colors">Library</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li aria-current="page"><span class="text-slate-700 font-medium">Brands</span></li>
          </ol>
        </nav>

        <h1 class="text-4xl sm:text-5xl font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-3">Browse by Brand</h1>
        <p class="text-lg text-slate-500">
          {sortedBrands.length} SaaS brands with {sortedBrands.reduce((sum, b) => sum + (b.emailCount || 0), 0)}+ lifecycle emails
        </p>
      </div>
    </div>

    <!-- Brand grid -->
    <section class="bg-[#FAFAFA] py-12 min-h-[400px]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedBrands.map((brand: any) => (
            <a
              href={`/library/brand/${brand.slug}`}
              class="group flex items-start gap-4 p-5 rounded-2xl border border-slate-100 bg-white hover:shadow-md transition-shadow"
            >
              <div class="w-12 h-12 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center overflow-hidden flex-shrink-0">
                {brand.logo ? (
                  <img src={brand.logo} alt={`${brand.name} logo`} class="w-8 h-8 object-contain" loading="lazy" />
                ) : (
                  <span class="text-lg font-bold text-slate-300">{brand.name.charAt(0)}</span>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <p class="font-semibold text-slate-900 group-hover:text-[#1D4ED8] transition-colors mb-1">
                  {brand.name}
                </p>
                <p class="text-xs text-slate-400">
                  {brand.emailCount} email{brand.emailCount !== 1 ? 's' : ''}
                  {brand.duration && <span> &middot; {brand.duration}</span>}
                </p>
                {brand.metaDesc && (
                  <p class="text-xs text-slate-500 mt-1 line-clamp-2 leading-relaxed">{brand.metaDesc}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</PageLayout>
