---
import PageLayout from '@/layouts/PageLayout.astro';
import emailsData from '@/data/library/emails.json';
import brandsData from '@/data/library/brands.json';
import tagsData from '@/data/library/tags.json';
import usecasesData from '@/data/library/usecases.json';

export function getStaticPaths() {
  return (tagsData as any[]).map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const { slug } = Astro.params;

const SITE_URL = 'https://www.digistorms.ai';
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`;

function truncateAtWord(text: string, limit: number): string {
  if (!text || text.length <= limit) return text ?? '';
  const cut = text.slice(0, limit);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 0 ? cut.slice(0, lastSpace) : cut) + '\u2026';
}

const filteredEmails = (emailsData as any[]).filter((e) => e.tags.includes(slug));
const sortedTags = [...(tagsData as any[])].sort((a, b) => a.name.localeCompare(b.name));

// Related use cases
const ucCounts: Record<string, number> = {};
filteredEmails.forEach((e) => {
  if (e.useCase) ucCounts[e.useCase] = (ucCounts[e.useCase] ?? 0) + 1;
});
const relatedUseCases = Object.entries(ucCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([ucSlug]) => (usecasesData as any[]).find((u) => u.slug === ucSlug))
  .filter(Boolean);

const rawDesc = tag.summary || `Browse ${filteredEmails.length} ${tag.name} emails from top B2B SaaS companies in the DigiStorms library.`;
const pageDesc = truncateAtWord(rawDesc, 155);
const pageUrl = `${SITE_URL}/library/tag/${slug}`;

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${tag.name} Emails \u2014 B2B SaaS Library`,
  description: pageDesc,
  url: pageUrl,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Library", item: `${SITE_URL}/library` },
    { "@type": "ListItem", position: 2, name: "Tags", item: `${SITE_URL}/library/tags` },
    { "@type": "ListItem", position: 3, name: tag.name, item: pageUrl },
  ],
};

const jsonLd = [collectionJsonLd, breadcrumbJsonLd];
---

<PageLayout
  title={`${tag.name} Emails \u2014 B2B SaaS Library | DigiStorms`}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={DEFAULT_OG_IMAGE}
  ogTitle={`${tag.name} Emails \u2014 DigiStorms Library`}
  ogDescription={pageDesc}
  jsonLd={jsonLd}
>
  <main class="pt-16">
    <!-- Page header -->
    <div class="bg-white border-b border-slate-100 pb-8 pt-10">
      <div class="container mx-auto px-4 max-w-6xl">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/library" class="hover:text-[#1D4ED8] transition-colors">Library</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li><a href="/library/tags" class="hover:text-[#1D4ED8] transition-colors">Tags</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li aria-current="page"><span class="text-slate-700 font-medium">{tag.name}</span></li>
          </ol>
        </nav>

        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-4"
          style="background: #EFF6FF; color: #1D4ED8;"
        >
          {tag.name}
        </div>
        <h1 class="text-4xl sm:text-5xl font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-2">{tag.name} emails</h1>
        <p class="text-slate-400 text-sm">
          {filteredEmails.length} email{filteredEmails.length !== 1 ? 's' : ''} in library
        </p>
        {tag.summary && (
          <div
            class="text-slate-500 text-sm mt-2 max-w-2xl leading-relaxed [&_p]:mb-2 [&_p:last-child]:mb-0"
            set:html={tag.summary}
          />
        )}

        {relatedUseCases.length > 0 && (
          <div class="mt-5">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wide mb-2">Related use cases</p>
            <div class="flex flex-wrap gap-2">
              {relatedUseCases.map((uc: any) => (
                <a
                  href={`/library/usecase/${uc.slug}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-slate-200 bg-white text-slate-600 hover:border-[#1D4ED8] hover:text-[#1D4ED8] hover:bg-[#DBEAFE] transition-all"
                >
                  {uc.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Tag tab navigation -->
    <div class="border-b border-slate-100 bg-white sticky top-16 z-10 shadow-sm">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="overflow-x-auto scrollbar-hide py-2">
          <div
            class="grid grid-rows-2 gap-1.5"
            style="grid-auto-flow: column; grid-auto-columns: max-content;"
          >
            {sortedTags.map((t: any) => (
              <a
                href={`/library/tag/${t.slug}`}
                class:list={[
                  'flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-all whitespace-nowrap',
                  t.slug === slug
                    ? 'text-white bg-[#1D4ED8]'
                    : 'text-slate-600 border border-slate-200 hover:border-[#1D4ED8] hover:text-[#1D4ED8] hover:bg-[#DBEAFE]',
                ]}
              >
                {t.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Email grid -->
    <section class="bg-[#FAFAFA] py-12 min-h-[400px]" aria-label={`${tag.name} emails`}>
      <div class="container mx-auto px-4 max-w-7xl">
        {filteredEmails.length === 0 ? (
          <div class="text-center py-20 text-slate-400">
            <p class="text-lg font-medium">No emails found for "{tag.name}".</p>
          </div>
        ) : (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {filteredEmails.map((email: any) => {
              const brand = (brandsData as any[]).find((b) => b.slug === email.brand);
              return (
                <a
                  href={`/library/email/${email.slug}`}
                  class="group rounded-xl border border-slate-100 bg-white overflow-hidden hover:shadow-md transition-shadow block"
                >
                  <div class="px-3 pt-3 pb-2">
                    <div class="flex items-center gap-1.5 mb-1">
                      {brand?.logo && (
                        <img src={brand.logo} alt={`${brand.name} logo`} class="h-3.5 w-3.5 object-contain" />
                      )}
                      <span class="text-[11px] text-slate-400 font-medium truncate">
                        {brand?.name ?? email.brand}
                      </span>
                    </div>
                    <p class="text-xs font-semibold text-slate-900 leading-snug line-clamp-2">
                      {email.subject || email.templateTitle}
                    </p>
                  </div>
                  <div class="relative overflow-hidden bg-slate-50 aspect-[4/3]">
                    {email.thumb ? (
                      <img
                        src={email.thumb}
                        alt={`${email.subject} \u2014 email screenshot from ${brand?.name ?? email.brand}`}
                        class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-[#DBEAFE] flex items-center justify-center">
                        <span class="text-4xl opacity-30">{"\u2709\uFE0F"}</span>
                      </div>
                    )}
                  </div>
                  {email.tags.length > 0 && (
                    <div class="px-3 pb-2.5 pt-1.5 flex flex-wrap gap-1">
                      {email.tags.slice(0, 2).map((tagSlug: string) => {
                        const tagObj = (tagsData as any[]).find((t) => t.slug === tagSlug);
                        return (
                          <span
                            class:list={[
                              'text-[10px] px-1.5 py-0.5 rounded-full',
                              tagSlug === slug
                                ? 'bg-[#1D4ED8] text-white'
                                : 'bg-[#DBEAFE] text-[#1D4ED8]',
                            ]}
                          >
                            {tagObj?.name ?? tagSlug}
                          </span>
                        );
                      })}
                      {email.tags.length > 2 && (
                        <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-400">
                          +{email.tags.length - 2}
                        </span>
                      )}
                    </div>
                  )}
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
</PageLayout>
