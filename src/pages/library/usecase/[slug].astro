---
import PageLayout from '@/layouts/PageLayout.astro';
import emailsData from '@/data/library/emails.json';
import brandsData from '@/data/library/brands.json';
import tagsData from '@/data/library/tags.json';
import usecasesData from '@/data/library/usecases.json';

export function getStaticPaths() {
  return (usecasesData as any[]).map((usecase) => ({
    params: { slug: usecase.slug },
    props: { usecase },
  }));
}

const { usecase } = Astro.props;
const { slug } = Astro.params;

const SITE_URL = 'https://www.digistorms.ai';
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`;

function truncateAtWord(text: string, limit: number): string {
  if (!text || text.length <= limit) return text ?? '';
  const cut = text.slice(0, limit);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 0 ? cut.slice(0, lastSpace) : cut) + '\u2026';
}

const filteredEmails = (emailsData as any[]).filter((e) => e.useCase === slug);
const sortedUseCases = [...(usecasesData as any[])].sort((a, b) => a.order - b.order);

// Group emails by brand
const emailsByBrand: Record<string, any[]> = {};
filteredEmails.forEach((e) => {
  if (!emailsByBrand[e.brand]) emailsByBrand[e.brand] = [];
  emailsByBrand[e.brand].push(e);
});
Object.values(emailsByBrand).forEach((g) =>
  g.sort((a: any, b: any) => new Date(a.setDate).getTime() - new Date(b.setDate).getTime())
);

// Top tags for this use case
const tagCounts: Record<string, number> = {};
filteredEmails.forEach((e) => {
  (e.tags ?? []).forEach((t: string) => { tagCounts[t] = (tagCounts[t] ?? 0) + 1; });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tagSlug]) => (tagsData as any[]).find((t) => t.slug === tagSlug))
  .filter(Boolean);

const rawDesc = usecase.description || `Browse ${filteredEmails.length} ${usecase.name} emails from top B2B SaaS companies.`;
const pageDesc = truncateAtWord(rawDesc, 155);
const pageUrl = `${SITE_URL}/library/usecase/${slug}`;

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${usecase.name} Emails — B2B SaaS Library`,
  description: pageDesc,
  url: pageUrl,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Library", item: `${SITE_URL}/library` },
    { "@type": "ListItem", position: 2, name: "Use Cases", item: `${SITE_URL}/library/usecases` },
    { "@type": "ListItem", position: 3, name: usecase.name, item: pageUrl },
  ],
};

const jsonLd = [collectionJsonLd, breadcrumbJsonLd];
---

<PageLayout
  title={`${usecase.name} Emails — B2B SaaS Library | DigiStorms`}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={DEFAULT_OG_IMAGE}
  ogTitle={`${usecase.name} Emails — DigiStorms Library`}
  ogDescription={pageDesc}
  jsonLd={jsonLd}
>
  <main class="pt-16">
    <!-- Page header -->
    <div class="bg-white border-b border-slate-100 pb-8 pt-10">
      <div class="container mx-auto px-4 max-w-6xl">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/library" class="hover:text-[#1D4ED8] transition-colors">Library</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li><a href="/library/usecases" class="hover:text-[#1D4ED8] transition-colors">Use Cases</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li aria-current="page"><span class="text-slate-700 font-medium">{usecase.name}</span></li>
          </ol>
        </nav>

        <div
          class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-4"
          style="background: #EFF6FF; color: #1D4ED8;"
        >
          {usecase.name}
        </div>
        <h1 class="text-4xl sm:text-5xl font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-2">{usecase.name} emails</h1>
        <p class="text-slate-400 text-sm">
          {filteredEmails.length} email{filteredEmails.length !== 1 ? 's' : ''} in library
        </p>
        {usecase.description && (
          <p class="text-slate-500 text-sm mt-2 max-w-2xl leading-relaxed">{usecase.description}</p>
        )}

        {topTags.length > 0 && (
          <div class="mt-5">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wide mb-2">Common email types</p>
            <div class="flex flex-wrap gap-2">
              {topTags.map((tag: any) => (
                <a
                  href={`/library/tag/${tag.slug}`}
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border border-slate-200 bg-white text-slate-600 hover:border-[#1D4ED8] hover:text-[#1D4ED8] hover:bg-[#DBEAFE] transition-all"
                >
                  {tag.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Use case tab navigation -->
    <div class="border-b border-slate-100 bg-white sticky top-16 z-10 shadow-sm">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex gap-1 overflow-x-auto scrollbar-hide py-2">
          {sortedUseCases.map((uc: any) => (
            <a
              href={`/library/usecase/${uc.slug}`}
              class:list={[
                'flex-shrink-0 px-3 py-1.5 rounded-full text-sm font-medium transition-all whitespace-nowrap',
                uc.slug === slug ? 'text-white bg-[#1D4ED8]' : 'text-slate-600 hover:text-[#1D4ED8] hover:bg-[#DBEAFE]',
              ]}
            >
              {uc.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Emails grouped by brand -->
    <section class="bg-[#FAFAFA] py-12 min-h-[400px]" aria-label={`${usecase.name} emails by brand`}>
      <div class="container mx-auto px-4 max-w-7xl">
        {filteredEmails.length === 0 ? (
          <div class="text-center py-20 text-slate-400">
            <p class="text-lg font-medium">No emails found for {usecase.name}.</p>
          </div>
        ) : (
          <div class="space-y-14">
            {Object.entries(emailsByBrand)
              .sort(([, a], [, b]) => b.length - a.length)
              .map(([brandSlug, emails]) => {
                const brand = (brandsData as any[]).find((b) => b.slug === brandSlug);
                return (
                  <div>
                    <div class="flex items-center gap-3 mb-5">
                      {brand?.logo && (
                        <img src={brand.logo} alt="" class="w-5 h-5 object-contain" loading="lazy" />
                      )}
                      <h2 class="text-base font-semibold text-slate-900">
                        <a href={`/library/brand/${brandSlug}`} class="hover:text-[#1D4ED8] transition-colors">
                          {brand?.name ?? brandSlug}
                        </a>
                      </h2>
                      <span class="text-xs text-slate-400 font-medium px-2 py-0.5 rounded-full bg-slate-100">
                        {emails.length} email{emails.length !== 1 ? 's' : ''}
                      </span>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
                      {emails.map((email: any) => (
                        <a
                          href={`/library/email/${email.slug}`}
                          class="group rounded-xl border border-slate-100 bg-white overflow-hidden hover:shadow-md transition-shadow block"
                        >
                          <div class="px-3 pt-3 pb-2">
                            <p class="text-xs font-semibold text-slate-900 leading-snug line-clamp-2">
                              {email.subject || email.templateTitle}
                            </p>
                          </div>
                          <div class="relative overflow-hidden bg-slate-50 aspect-[4/3]">
                            {email.thumb ? (
                              <img
                                src={email.thumb}
                                alt={`${email.subject} — email screenshot from ${brand?.name ?? brandSlug}`}
                                class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
                                loading="lazy"
                              />
                            ) : (
                              <div class="w-full h-full bg-[#DBEAFE] flex items-center justify-center">
                                <span class="text-4xl opacity-30">{"\u2709\uFE0F"}</span>
                              </div>
                            )}
                          </div>
                          {email.tags.length > 0 && (
                            <div class="px-3 pb-2.5 pt-1.5 flex flex-wrap gap-1">
                              {email.tags.slice(0, 2).map((tagSlug: string) => {
                                const tagObj = (tagsData as any[]).find((t) => t.slug === tagSlug);
                                return (
                                  <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-[#DBEAFE] text-[#1D4ED8]">
                                    {tagObj?.name ?? tagSlug}
                                  </span>
                                );
                              })}
                              {email.tags.length > 2 && (
                                <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-400">
                                  +{email.tags.length - 2}
                                </span>
                              )}
                            </div>
                          )}
                        </a>
                      ))}
                    </div>
                  </div>
                );
              })}
          </div>
        )}
      </div>
    </section>
  </main>
</PageLayout>
