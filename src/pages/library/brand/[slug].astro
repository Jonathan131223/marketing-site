---
import PageLayout from '@/layouts/PageLayout.astro';
import emailsData from '@/data/library/emails.json';
import brandsData from '@/data/library/brands.json';
import tagsData from '@/data/library/tags.json';
import usecasesData from '@/data/library/usecases.json';

export function getStaticPaths() {
  return (brandsData as any[]).map((brand) => ({
    params: { slug: brand.slug },
    props: { brand },
  }));
}

const { brand } = Astro.props;
const { slug } = Astro.params;

const SITE_URL = 'https://www.digistorms.ai';
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`;

function truncateAtWord(text: string, limit: number): string {
  if (!text || text.length <= limit) return text ?? '';
  const cut = text.slice(0, limit);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 0 ? cut.slice(0, lastSpace) : cut) + '\u2026';
}

function formatDate(raw: string): string {
  if (!raw) return '';
  try {
    return new Date(raw).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch { return raw; }
}

const filteredEmails = (emailsData as any[]).filter((e) => e.brand === slug);
const sortedBrands = [...(brandsData as any[])].sort((a, b) => a.name.localeCompare(b.name));
const sortedUseCases = [...(usecasesData as any[])].sort((a, b) => a.order - b.order);

// Group emails by use case
const emailsByUseCase: Record<string, any[]> = {};
filteredEmails.forEach((e) => {
  if (!emailsByUseCase[e.useCase]) emailsByUseCase[e.useCase] = [];
  emailsByUseCase[e.useCase].push(e);
});
Object.values(emailsByUseCase).forEach((g) =>
  g.sort((a: any, b: any) => new Date(a.setDate).getTime() - new Date(b.setDate).getTime())
);

// Top tags for this brand
const tagCounts: Record<string, number> = {};
filteredEmails.forEach((e) => {
  (e.tags ?? []).forEach((t: string) => { tagCounts[t] = (tagCounts[t] ?? 0) + 1; });
});
const topBrandTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([tagSlug]) => (tagsData as any[]).find((t) => t.slug === tagSlug))
  .filter(Boolean);

const pageTitle = `${brand.name} Emails \u2014 B2B SaaS Library | DigiStorms`;
const rawDesc = brand.metaDesc || `Browse all ${brand.name} lifecycle emails in the DigiStorms library.`;
const pageDesc = truncateAtWord(rawDesc, 155);
const pageUrl = `${SITE_URL}/library/brand/${slug}`;
const ogImage = brand.logo || DEFAULT_OG_IMAGE;

const collectionJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: pageTitle,
  description: pageDesc,
  url: pageUrl,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Library", item: `${SITE_URL}/library` },
    { "@type": "ListItem", position: 2, name: "Brands", item: `${SITE_URL}/library/brands` },
    { "@type": "ListItem", position: 3, name: brand.name, item: pageUrl },
  ],
};

const jsonLd = [collectionJsonLd, breadcrumbJsonLd];
---

<PageLayout
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  ogImage={ogImage}
  ogTitle={pageTitle}
  ogDescription={pageDesc}
  jsonLd={jsonLd}
>
  <main class="pt-16">
    <!-- Page header -->
    <div class="bg-white border-b border-slate-100 pb-8 pt-10">
      <div class="container mx-auto px-4 max-w-6xl">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/library" class="hover:text-[#1D4ED8] transition-colors">Library</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li><a href="/library/brands" class="hover:text-[#1D4ED8] transition-colors">Brands</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li aria-current="page"><span class="text-slate-700 font-medium">{brand.name}</span></li>
          </ol>
        </nav>

        <!-- Header: logo + name + summary + stats -->
        <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-10">
          <div class="flex items-start gap-5 flex-1 min-w-0">
            {brand.logo && (
              <div class="w-16 h-16 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center overflow-hidden flex-shrink-0 shadow-sm">
                <img src={brand.logo} alt={`${brand.name} logo`} class="w-10 h-10 object-contain" />
              </div>
            )}
            <div class="min-w-0">
              <h1 class="text-4xl sm:text-5xl font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-3">{brand.name}</h1>
              {brand.summary && (
                <div
                  class="text-slate-500 text-sm leading-relaxed max-w-2xl [&_p]:mb-2 [&_p:last-child]:mb-0"
                  set:html={brand.summary}
                />
              )}
            </div>
          </div>

          <div class="md:flex-shrink-0 md:w-52">
            <div class="rounded-xl border border-slate-100 bg-[#FAFAFA] p-4">
              <ul class="space-y-2 mb-4">
                {filteredEmails.length > 0 && (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="text-[#1D4ED8] font-bold">&middot;</span>
                    <span>{filteredEmails.length} email{filteredEmails.length !== 1 ? 's' : ''}</span>
                  </li>
                )}
                {brand.duration && (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="text-[#1D4ED8] font-bold">&middot;</span>
                    <span>{brand.duration}</span>
                  </li>
                )}
                {brand.avgDelay && (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="text-[#1D4ED8] font-bold">&middot;</span>
                    <span>avg {brand.avgDelay} between sends</span>
                  </li>
                )}
              </ul>
            </div>
          </div>
        </div>

        {/* Top tags */}
        {topBrandTags.length > 0 && (
          <div class="mt-6">
            <p class="text-xs text-slate-400 font-medium uppercase tracking-wide mb-2 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
              Common email types
            </p>
            <div class="flex flex-wrap gap-2">
              {topBrandTags.map((tag: any) => (
                <a
                  href={`/library/tag/${tag.slug}`}
                  class="inline-block px-3 py-1 rounded-full text-xs font-medium border border-slate-200 bg-white text-slate-600 hover:border-[#1D4ED8] hover:text-[#1D4ED8] hover:bg-[#DBEAFE] transition-all"
                >
                  {tag.name}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Brand tab navigation -->
    <div class="border-b border-slate-100 bg-white sticky top-16 z-10 shadow-sm">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex gap-1 overflow-x-auto scrollbar-hide py-2">
          {sortedBrands.map((b: any) => (
            <a
              href={`/library/brand/${b.slug}`}
              title={b.name}
              class:list={[
                'flex-shrink-0 flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium transition-all whitespace-nowrap',
                b.slug === slug ? 'text-white bg-[#1D4ED8]' : 'text-slate-600 hover:text-[#1D4ED8] hover:bg-[#DBEAFE]',
              ]}
            >
              {b.logo && (
                <img src={b.logo} alt="" class="w-4 h-4 object-contain flex-shrink-0" loading="lazy" />
              )}
              {b.name}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Emails grouped by use case -->
    <section class="bg-[#FAFAFA] py-12 min-h-[400px]" aria-label={`${brand.name} emails by use case`}>
      <div class="container mx-auto px-4 max-w-7xl">
        {filteredEmails.length === 0 ? (
          <div class="text-center py-20 text-slate-400">
            <p class="text-lg font-medium">No emails found for {brand.name}.</p>
          </div>
        ) : (
          <div class="space-y-14">
            {sortedUseCases.map((uc: any) => {
              const ucEmails = emailsByUseCase[uc.slug];
              if (!ucEmails?.length) return null;
              return (
                <div>
                  <div class="flex items-center gap-3 mb-5">
                    <h2 class="text-base font-semibold text-slate-900">
                      <a href={`/library/usecase/${uc.slug}`} class="hover:text-[#1D4ED8] transition-colors">
                        {uc.name}
                      </a>
                    </h2>
                    <span class="text-xs text-slate-400 font-medium px-2 py-0.5 rounded-full bg-slate-100">
                      {ucEmails.length} email{ucEmails.length !== 1 ? 's' : ''}
                    </span>
                  </div>

                  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
                    {ucEmails.map((email: any) => (
                      <a
                        href={`/library/email/${email.slug}`}
                        class="group rounded-xl border border-slate-100 bg-white overflow-hidden hover:shadow-md transition-shadow block"
                      >
                        <div class="px-3 pt-3 pb-2">
                          <p class="text-xs font-semibold text-slate-900 leading-snug line-clamp-2">
                            {email.subject || email.templateTitle}
                          </p>
                        </div>
                        <div class="relative overflow-hidden bg-slate-50 aspect-[4/3]">
                          {email.thumb ? (
                            <img
                              src={email.thumb}
                              alt={`${email.subject} \u2014 email screenshot from ${brand.name}`}
                              class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
                              loading="lazy"
                            />
                          ) : (
                            <div class="w-full h-full bg-[#DBEAFE] flex items-center justify-center">
                              <span class="text-4xl opacity-30">{"\u2709\uFE0F"}</span>
                            </div>
                          )}
                        </div>
                        {email.tags.length > 0 && (
                          <div class="px-3 pb-2.5 pt-1.5 flex flex-wrap gap-1">
                            {email.tags.slice(0, 2).map((tagSlug: string) => {
                              const tagObj = (tagsData as any[]).find((t) => t.slug === tagSlug);
                              return (
                                <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-[#DBEAFE] text-[#1D4ED8]">
                                  {tagObj?.name ?? tagSlug}
                                </span>
                              );
                            })}
                            {email.tags.length > 2 && (
                              <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-400">
                                +{email.tags.length - 2}
                              </span>
                            )}
                          </div>
                        )}
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
</PageLayout>
