---
import PageLayout from '@/layouts/PageLayout.astro';
import tagsData from '@/data/library/tags.json';
import emailsData from '@/data/library/emails.json';

const SITE_URL = 'https://www.digistorms.ai';
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/7e09a043-6588-42c9-bb0d-6d8f4d6da036.png`;

// Count emails per tag
const tagEmailCounts: Record<string, number> = {};
(emailsData as any[]).forEach((e) => {
  (e.tags ?? []).forEach((t: string) => {
    tagEmailCounts[t] = (tagEmailCounts[t] ?? 0) + 1;
  });
});

const sortedTags = [...(tagsData as any[])]
  .map((tag) => ({ ...tag, count: tagEmailCounts[tag.slug] ?? 0 }))
  .sort((a, b) => b.count - a.count);

const PAGE_TITLE = 'Browse Email Library by Tag | DigiStorms';
const PAGE_DESC = 'Explore lifecycle emails organized by email type: welcome emails, feature nudges, upgrade prompts, billing reminders, and 50+ more tags.';
const pageUrl = `${SITE_URL}/library/tags`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: PAGE_TITLE,
  description: PAGE_DESC,
  url: pageUrl,
  breadcrumb: {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Library", item: `${SITE_URL}/library` },
      { "@type": "ListItem", position: 2, name: "Tags", item: pageUrl },
    ],
  },
};
---

<PageLayout
  title={PAGE_TITLE}
  description={PAGE_DESC}
  canonical={pageUrl}
  ogTitle={PAGE_TITLE}
  ogDescription={PAGE_DESC}
  ogImage={DEFAULT_OG_IMAGE}
  jsonLd={jsonLd}
>
  <main class="pt-16">
    <!-- Page header -->
    <div class="bg-white border-b border-slate-100 pb-8 pt-10">
      <div class="container mx-auto px-4 max-w-6xl">
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-slate-400">
            <li><a href="/library" class="hover:text-[#1D4ED8] transition-colors">Library</a></li>
            <li aria-hidden="true"><span>/</span></li>
            <li aria-current="page"><span class="text-slate-700 font-medium">Tags</span></li>
          </ol>
        </nav>

        <h1 class="text-4xl sm:text-5xl font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-3">Browse by Tag</h1>
        <p class="text-lg text-slate-500">
          {sortedTags.length} email types across all brands
        </p>
      </div>
    </div>

    <!-- Tags grid -->
    <section class="bg-[#FAFAFA] py-12 min-h-[400px]">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {sortedTags.map((tag: any) => (
            <a
              href={`/library/tag/${tag.slug}`}
              class="group flex items-center justify-between p-4 rounded-xl border border-slate-100 bg-white hover:shadow-md transition-shadow"
            >
              <div class="min-w-0 flex-1">
                <p class="font-semibold text-slate-900 group-hover:text-[#1D4ED8] transition-colors text-sm">
                  {tag.name}
                </p>
                {tag.summary && (
                  <p class="text-xs text-slate-500 mt-0.5 line-clamp-1 leading-relaxed">{tag.summary}</p>
                )}
              </div>
              <span class="flex-shrink-0 ml-3 text-xs font-medium px-2.5 py-1 rounded-full bg-slate-100 text-slate-500">
                {tag.count}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</PageLayout>
