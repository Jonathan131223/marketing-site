---
import PageLayout from '@/layouts/PageLayout.astro';
import LifecycleScoreIsland from '@/components/react/LifecycleScoreIsland';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "DigiStorms Lifecycle Score",
  "url": "https://www.digistorms.ai/lifecycle-score",
  "applicationCategory": "BusinessApplication",
  "description": "Score your SaaS onboarding and lifecycle email setup. Get actionable recommendations to improve activation.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
};
---

<PageLayout
  ogImage="https://www.digistorms.ai/og/lifecycle-score.webp"
  title="Free SaaS Onboarding Score Quiz — DigiStorms"
  description="Take a quick quiz to score your current SaaS onboarding and lifecycle email setup. Get personalized recommendations to improve activation and conversion."
  jsonLd={jsonLd}
>
  <LifecycleScoreIsland client:visible />
</PageLayout>
