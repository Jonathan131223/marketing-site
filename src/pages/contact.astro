---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/react/ContactForm';
---

<PageLayout
  title="Contact Us | DigiStorms"
  description="Get in touch with the DigiStorms team. We help SaaS companies build lifecycle email sequences that drive activation, retention, and revenue."
>
  <main class="container mx-auto px-4 pt-24 pb-16">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <p class="text-[13px] font-semibold tracking-[0.08em] uppercase text-primary mb-3">
          Contact
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-serif text-slate-900 leading-[1.1] tracking-[-0.02em] mb-4">
          Get in touch
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">
          Have questions about DigiStorms? Want to discuss how we can help your business?
          We'd love to hear from you.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <ContactForm client:visible />
      </div>
    </div>
  </main>
</PageLayout>
