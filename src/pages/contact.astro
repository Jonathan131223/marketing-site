---
import PageLayout from '@/layouts/PageLayout.astro';
import ContactForm from '@/components/react/ContactForm';
---

<PageLayout
  title="Contact Us | DigiStorms"
  description="Get in touch with the DigiStorms team. We help SaaS companies build lifecycle email sequences that drive activation, retention, and revenue."
>
  <main class="container mx-auto px-4 py-16">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-foreground mb-4">
          Get in Touch
        </h1>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          Have questions about DigiStorms? Want to discuss how we can help your business?
          We'd love to hear from you.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <ContactForm client:visible />
      </div>
    </div>
  </main>
</PageLayout>
