---
import PageLayout from '@/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import jonProfile from '@/assets/founder/jonathan-profile.png';

// Consulting testimonials — from the pre-DigiStorms freelance engagements.
// About-page-only (not used on the homepage). Images live in
// /public/images-testimonials/ (served at /images-testimonials/*.webp).
const testimonials = [
  {
    company: "Triscale",
    industry: "GTM Expert",
    quote: "I've had the pleasure of collaborating with Jonathan on several projects, and his expertise in lifecycle marketing for B2B SaaS is outstanding. He deeply understands how to drive engagement and retention through smart, data-driven campaigns. Beyond his skills, he's a fantastic partner — insightful, proactive, and always focused on impact. I highly recommend working with him!",
    author: "Thibault Le Meur",
    logoUrl: "/images-testimonials/triscale.webp",
    avatarUrl: "/images-testimonials/thibault.webp",
  },
  {
    company: "BryteBridge",
    industry: "Non-Profit Solutions",
    quote: "Jonathan is a rising star in Lifecycle Marketing and one of a few trusted freelancers I send referrals to. If you need help going 0 to 1 on your B2B SaaS lifecycle programs, give Jonathan a shout. His attitude, quality, and speed to delivery are all top-notch.",
    author: "Drew Price",
    logoUrl: "/images-testimonials/brytebridge.webp",
    avatarUrl: "/images-testimonials/drew.webp",
  },
  {
    company: "Blaze Type",
    industry: "Font Solutions",
    quote: "Jonathan's approach to retention has been a game-changer for us. Our customer lifetime value has significantly increased.",
    author: "Matthieu Salvaggio",
    logoUrl: "/images-testimonials/blaze.webp",
    avatarUrl: "/images-testimonials/matt.webp",
  },
  {
    company: "Magrid",
    industry: "EdTech",
    quote: "The team's expertise in email marketing transformed our user engagement metrics. We've never seen such positive results!",
    author: "Tahereh Pazouki",
    logoUrl: "/images-testimonials/magrid.webp",
    avatarUrl: "/images-testimonials/tahereh.webp",
  },
  {
    company: "Bubbleye",
    industry: "Marketing Automation",
    quote: "Jonathan's professionalism, speed, and competence in writing and strategic planning are remarkable. I highly recommend him.",
    author: "Stefano Roncari",
    logoUrl: "/images-testimonials/bubbleye_logo.webp",
    avatarUrl: "/images-testimonials/stefano.webp",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About DigiStorms",
  "description": "DigiStorms started from consulting with SaaS companies on lifecycle email. We built an AI agent to automate onboarding email systems.",
  "url": "https://www.digistorms.ai/about",
  "mainEntity": {
    "@type": "Organization",
    "name": "DigiStorms",
    "url": "https://www.digistorms.ai",
    "founder": {
      "@type": "Person",
      "name": "Jonathan Bernard",
      "url": "https://www.linkedin.com/in/jonathan-digistorms/",
      "jobTitle": "Founder"
    },
    "description": "AI agent that builds lifecycle email systems for SaaS companies"
  }
};
---

<PageLayout
  title="About DigiStorms — From Consulting to AI Onboarding Agent"
  description="DigiStorms started from consulting with SaaS companies on lifecycle email. After seeing the same onboarding problems everywhere, we built an AI agent to automate what we were doing manually."
  ogTitle="About DigiStorms — From Consulting to AI Onboarding Agent"
  ogDescription="How a consulting pattern became an AI agent for onboarding emails."
  jsonLd={jsonLd}
>
  <main class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/4 w-72 h-72 bg-blue-100/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-100/20 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-4xl mx-auto px-6 py-16 relative z-10">

      <!-- Header -->
      <div class="text-center mb-20">
        <p class="text-[13px] font-semibold tracking-[0.08em] uppercase text-primary mb-3">
          About
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-[52px] font-serif text-slate-900 mb-4 leading-[1.1] tracking-[-0.02em]">
          The story behind DigiStorms
        </h1>
        <p class="text-lg text-slate-500">
          How a consulting pattern became an AI agent
        </p>
      </div>

      <!-- Section 1 -->
      <section class="mb-20">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-8">It started with a pattern</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          After working with dozens of SaaS companies on their lifecycle email strategy, one thing kept coming up: every team was solving the same problem from scratch. They'd analyze their user journey, map out the onboarding milestones, figure out what emails to send and when — then spend weeks building it all manually. The process was the same every time. The emails were different, but the system behind them wasn't.
        </p>
      </section>

      <!-- Section 2 -->
      <section class="mb-20">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-8">From consulting to product</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          DigiStorms started as that consulting process — helping SaaS teams build onboarding email systems by hand. But the more companies we worked with, the clearer it became: this should be automated. An AI that understands your product, maps the user journey, and generates the right emails at the right time — that's what every team actually needs. So we built it.
        </p>
      </section>

      <!-- Section 3 -->
      <section class="mb-20">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-8">Trained on 1,000+ real emails</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          We studied lifecycle emails from 38+ SaaS companies — Notion, Slack, Stripe, HubSpot, Intercom, and many more. We analyzed what the best onboarding sequences have in common: timing, triggers, tone, structure. That research is the foundation DigiStorms is built on. It's also available to everyone in our email library — the largest collection of B2B SaaS lifecycle emails on the web.
        </p>
      </section>

      <!-- Section 4 — Founder -->
      <section class="mb-20">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-8">Built by Jonathan Bernard</h2>
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-8 flex flex-col sm:flex-row items-center sm:items-start gap-8">
          <Image
            src={jonProfile}
            alt="Jonathan Bernard, Founder of DigiStorms"
            class="w-28 h-28 rounded-full object-cover flex-shrink-0"
            loading="lazy"
            decoding="async"
            width={112}
            height={112}
          />
          <div>
            <p class="text-xl font-semibold text-slate-900">Jonathan Bernard</p>
            <p class="text-base text-slate-500 mb-4">Founder, DigiStorms</p>
            <p class="text-lg text-slate-600 leading-relaxed mb-4">
              Lifecycle email specialist for SaaS companies. Previously consulted with growth teams on onboarding, retention, and expansion strategy. Now building the AI that does it automatically.
            </p>
            <a
              href="https://www.linkedin.com/in/jonathan-digistorms/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-[#1D4ED8] font-medium hover:underline"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              Connect on LinkedIn
            </a>
          </div>
        </div>
      </section>

      <!-- Section 5 — Consulting testimonials -->
      <section class="mb-20">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-3">What consulting clients say</h2>
        <p class="text-lg text-slate-500 mb-10">
          Before building DigiStorms, Jonathan worked directly with SaaS growth teams on their lifecycle email programs.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {testimonials.map((t) => (
            <figure class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm flex flex-col">
              <div class="flex items-center gap-3 mb-4">
                <img
                  src={t.logoUrl}
                  alt={`${t.company} logo`}
                  class="h-10 w-10 rounded-lg object-contain flex-shrink-0"
                  width="40"
                  height="40"
                  loading="lazy"
                  decoding="async"
                />
                <div>
                  <p class="font-semibold text-slate-900 leading-tight">{t.company}</p>
                  <p class="text-xs text-slate-500">{t.industry}</p>
                </div>
              </div>
              <blockquote class="text-slate-600 text-[15px] leading-relaxed mb-5 flex-1">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <figcaption class="flex items-center gap-3 pt-4 border-t border-slate-100">
                <img
                  src={t.avatarUrl}
                  alt={t.author}
                  class="h-10 w-10 rounded-full object-cover flex-shrink-0"
                  width="40"
                  height="40"
                  loading="lazy"
                  decoding="async"
                />
                <p class="text-sm font-medium text-slate-900">{t.author}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

    </div>

    <!-- CTA -->
    <section class="pb-20 px-6">
      <div class="max-w-2xl mx-auto text-center bg-white rounded-3xl border border-slate-100 px-8 py-14">
        <h2 class="text-3xl sm:text-4xl font-serif text-slate-900 tracking-[-0.01em] mb-3">Ready to automate your onboarding?</h2>
        <p class="text-lg text-slate-600 mb-8">Enter your website and get a complete email sequence in minutes.</p>
        <a
          href="/"
          class="inline-block bg-primary text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-[#1E40AF] transition-colors"
        >
          Generate my onboarding emails →
        </a>
      </div>
    </section>

  </main>
</PageLayout>
