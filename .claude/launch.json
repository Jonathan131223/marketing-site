{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "digi-marketing-dev",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/astro", "dev", "--port", "${port}"],
      "port": 4321,
      "autoPort": true
    },
    {
      "name": "digi-marketing-preview",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/astro", "preview"],
      "port": 4321,
      "autoPort": true
    }
  ]
}
