# Where app CTAs point (Sign up, Login, Generate, etc.)
# PUBLIC_ prefix so Astro inlines it into both server AND client bundles.
# Without PUBLIC_, server and client disagree on the URL and React throws
# a hydration mismatch warning in <Navbar client:load>.
#
# Production: app on subdomain
# PUBLIC_APP_BASE_URL=https://app.digistorms.ai
# Testing: app on same domain as marketing
# PUBLIC_APP_BASE_URL=https://digistorms.ai
# Local app (digi-monorepo on port 8080)
# PUBLIC_APP_BASE_URL=http://localhost:8080

PUBLIC_APP_BASE_URL=https://digistorms.ai
