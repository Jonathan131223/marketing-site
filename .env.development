# App URL for Sign up / Login and all product CTAs (marketing only reads this).
# Testing: use digistorms.ai so app and marketing are same origin.
# Override in .env.local for production (app.digistorms.ai) or local app (http://localhost:8080).
# PUBLIC_ prefix so Astro inlines it into both server AND client bundles.
PUBLIC_APP_BASE_URL=https://digistorms.ai
